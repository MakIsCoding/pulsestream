# PulseStream — cloud environment template
# Copy this file to .env.cloud and fill in your credentials.
# .env.cloud is git-ignored and never committed.
#
# Free-tier services needed:
#   Postgres → Neon     https://neon.tech
#   Redis    → Upstash  https://upstash.com  (Redis tab)
#   Kafka    → Aiven    https://console.aiven.io  (free tier, usage-capped)

# ─────────────────────────────────────────────────────────
# DATABASE — Neon PostgreSQL
#
# 1. Create a project at neon.tech
# 2. Dashboard → Connection Details
# 3. Select "Pooled connection" toggle
# 4. Copy the connection string and change "postgresql://" → "postgresql+asyncpg://"
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb
DATABASE_SSL=true

# These are only needed if a service reads them individually (keep them in sync with DATABASE_URL)
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=neondb
POSTGRES_HOST=ep-xxx-pooler.us-east-2.aws.neon.tech
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────
# REDIS — Upstash
#
# 1. Create a Redis database at upstash.com
# 2. Database page → Details → "Redis URL"  (starts with rediss://)
# ─────────────────────────────────────────────────────────
REDIS_URL=rediss://default:password@your-endpoint.upstash.io:6380
REDIS_HOST=your-endpoint.upstash.io
REDIS_PORT=6380

# ─────────────────────────────────────────────────────────
# KAFKA — Aiven (free tier, usage-capped, no expiry)
#
# 1. Create a free Kafka service at console.aiven.io
# 2. Service page → Connection information:
#    - Host:Port  → KAFKA_BOOTSTRAP_SERVERS  (e.g. kafka-xxx.aivencloud.com:PORT)
#    - User       → KAFKA_SASL_USERNAME      (usually "avnadmin")
#    - Password   → KAFKA_SASL_PASSWORD
# 3. Download CA Certificate (ca.pem) from the same page, then base64-encode it:
#      Linux/Mac:  base64 -w 0 ca.pem
#      Windows:    certutil -encode ca.pem tmp.b64 && findstr /v CERTIFICATE tmp.b64
#    Paste the single-line result as KAFKA_SSL_CA_CERT
# 4. Create 4 topics in Aiven console: mentions.raw, mentions.analyzed,
#    topics.created, ingestion.jobs
# ─────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-xxx-projectname.aivencloud.com:PORT
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=avnadmin
KAFKA_SASL_PASSWORD=your-kafka-password
KAFKA_SSL_CA_CERT=base64-encoded-ca.pem-contents

# Topic names — keep the defaults
KAFKA_TOPIC_MENTIONS_RAW=mentions.raw
KAFKA_TOPIC_MENTIONS_ANALYZED=mentions.analyzed
KAFKA_TOPIC_TOPICS_CREATED=topics.created
KAFKA_TOPIC_INGESTION_JOBS=ingestion.jobs

# ─────────────────────────────────────────────────────────
# AUTH
# Generate a strong secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────
JWT_SECRET=replace-me-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────────────────────
# AI
# ─────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
LLM_PROVIDER=groq
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────
# REDDIT  (optional — leave blank to skip Reddit ingestion)
# ─────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulsestream/0.1

# ─────────────────────────────────────────────────────────
# SCHEDULER
# Increase interval to stay within free-tier API rate limits
# ─────────────────────────────────────────────────────────
INGESTION_INTERVAL_SECONDS=300
MENTION_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────
# WEBSOCKET URL
# Local: ws://localhost:8001
# Railway: wss://your-websocket-service.up.railway.app
# (Set this in the web service's env vars AFTER deploying websocket)
# ─────────────────────────────────────────────────────────
WEBSOCKET_URL=ws://localhost:8001

# ─────────────────────────────────────────────────────────
# PORTS  (for local cloud-mode testing via docker-compose.cloud.yml)
# ─────────────────────────────────────────────────────────
WEB_PORT=8000
WEBSOCKET_PORT=8001
