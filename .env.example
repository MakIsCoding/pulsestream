# === Database ===
POSTGRES_USER=pulsestream
POSTGRES_PASSWORD=pulsestream_dev_password
POSTGRES_DB=pulsestream
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://pulsestream:pulsestream_dev_password@postgres:5432/pulsestream

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_MENTIONS_RAW=mentions.raw
KAFKA_TOPIC_MENTIONS_ANALYZED=mentions.analyzed
KAFKA_TOPIC_TOPICS_CREATED=topics.created
KAFKA_TOPIC_INGESTION_JOBS=ingestion.jobs

# === Auth ===
JWT_SECRET=change-this-to-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# === AI (Google Gemini) ===
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# === Reddit (optional, for ingester) ===
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulsestream/0.1

# === Scheduler ===
INGESTION_INTERVAL_SECONDS=60

# === Service ports (for local dev) ===
WEB_PORT=8000
WEBSOCKET_PORT=8001
PGADMIN_PORT=5050
KAFKA_UI_PORT=8080
